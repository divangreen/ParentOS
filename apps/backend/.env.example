# Supabase — get these from your project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWTs are verified against SUPABASE_URL's JWKS endpoint (app/dependencies.py) — no separate secret needed
# Public/anon key -- used only by tests/test_rls.py to verify RLS blocks anonymous access
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# AI
AI_PROVIDER=openai          # openai | ollama
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# App
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000"]
